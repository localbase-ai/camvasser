generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Appointment {
  id              String   @id
  leadId          String?
  tenant          String
  googleEventId   String?
  summary         String
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int      @default(60)
  location        String?
  notes           String?
  status          String   @default("scheduled")
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  eventType       String   @default("sales")

  @@index([eventType])
  @@index([googleEventId])
  @@index([leadId])
  @@index([startTime])
  @@index([status])
  @@index([tenant])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Lead {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String    @default("")
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  projectId     String?
  tenant        String
  status        String    @default("new")
  source        String?
  leadSource    String?
  dataSource    String?
  ownerName     String?
  notes         String?
  coordinates   Json?
  flowData      Json?
  search_vector Unsupported("tsvector")?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenant])
  @@index([status])
  @@index([createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BackgroundJob {
  id        String   @id
  type      String
  status    String   @default("pending")
  input     Json?
  result    Json?
  error     String?
  progress  Int      @default(0)
  total     Int      @default(0)
  tenant    String?
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([createdAt])
  @@index([status])
  @@index([tenant])
  @@index([type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BusinessUser {
  id                 String               @id
  name               String
  email              String               @unique
  phone              String?
  companyName        String?
  slug               String?
  createdAt          DateTime             @default(now())
  approvedAt         DateTime?
  status             String               @default("pending")
  passwordHash       String?
  isAdmin            Boolean              @default(false)
  CallListAssignment CallListAssignment[]
  UserTenant         UserTenant[]

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CallList {
  id                 String               @id
  name               String
  tenantId           String
  userId             String
  createdAt          DateTime             @default(now())
  assignedToUserId   String?
  scriptId           String?
  CallScript         CallScript?          @relation(fields: [scriptId], references: [id])
  CallListAssignment CallListAssignment[]
  CallListItem       CallListItem[]

  @@index([assignedToUserId])
  @@index([scriptId])
  @@index([tenantId])
  @@index([userId])
}

model CallListAssignment {
  id           String       @id
  callListId   String
  userId       String
  createdAt    DateTime     @default(now())
  CallList     CallList     @relation(fields: [callListId], references: [id], onDelete: Cascade)
  BusinessUser BusinessUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callListId, userId])
  @@index([callListId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CallListItem {
  id         String   @id
  callListId String
  contactId  String?
  leadId     String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  CallList   CallList @relation(fields: [callListId], references: [id], onDelete: Cascade)

  @@index([callListId])
  @@index([contactId])
  @@index([leadId])
}

model CallScript {
  id        String     @id
  name      String
  content   String
  tenantId  String
  createdBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  CallList  CallList[]

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Note {
  id         String   @id
  content    String
  entityType String
  entityId   String
  tenant     String
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([tenant])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OAuthToken {
  id           String   @id
  provider     String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  companyId    String?
  updatedAt    DateTime
  createdAt    DateTime @default(now())

  @@index([provider])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Organization {
  id                   String                 @id
  name                 String
  type                 String
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  phone                String?
  email                String?
  website              String?
  notes                String?
  tenant               String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  OrganizationContact  OrganizationContact[]
  OrganizationProperty OrganizationProperty[]

  @@index([name])
  @@index([tenant])
  @@index([type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrganizationContact {
  id             String       @id
  organizationId String
  prospectId     String?
  name           String
  title          String?
  phone          String?
  email          String?
  isPrimary      Boolean      @default(false)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Prospect       Prospect?    @relation(fields: [prospectId], references: [id])

  @@index([organizationId])
  @@index([prospectId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrganizationProperty {
  id             String       @id
  organizationId String
  projectId      String
  relationship   String       @default("manages")
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId])
  @@index([organizationId])
  @@index([projectId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Project {
  id                   String                   @id
  tenant               String?
  companyId            String?
  creatorId            String?
  creatorType          String?
  creatorName          String?
  status               String?
  archived             Boolean                  @default(false)
  public               Boolean                  @default(true)
  name                 String?
  address              String?
  streetAddress2       String?
  city                 String?
  state                String?
  postalCode           String?
  country              String?
  slug                 String?
  projectUrl           String?
  publicUrl            String?
  embeddedProjectUrl   String?
  coordinates          Json?
  geofence             Json?
  featureImage         Json?
  photoCount           Int                      @default(0)
  photos               Json?
  videos               Json?
  documents            Json?
  integrations         Json?
  primaryContact       Json?
  notepad              String?
  lastSyncedAt         DateTime                 @default(now())
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime
  tags                 Json?
  ccCreatedAt          DateTime?
  ccUpdatedAt          DateTime?
  whitepagesEnrichedAt DateTime?
  search_vector        Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((((((((COALESCE(address, ''::text) || ' '::text) || COALESCE(city, ''::text)) || ' '::text) || COALESCE(state, ''::text)) || ' '::text) || COALESCE(\"postalCode\", ''::text)) || ' '::text) || COALESCE(name, ''::text)) || ' '::text) || COALESCE(notepad, ''::text)))"))
  OrganizationProperty OrganizationProperty[]
  ProjectLabel         ProjectLabel[]
  Prospect             Prospect[]

  @@index([address])
  @@index([ccUpdatedAt])
  @@index([city, state])
  @@index([lastSyncedAt])
  @@index([status])
  @@index([tenant])
  @@index([search_vector], map: "project_search_idx", type: Gin)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProjectLabel {
  id           String   @id
  projectId    String
  labelId      String
  displayValue String
  value        String
  tagType      String
  createdAt    DateTime @default(now())
  Project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([value])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Proposal {
  id             String    @id
  proposalId     String    @unique
  customerName   String?
  customerEmail  String?
  proposalAmount Float?
  sentDate       DateTime?
  signedDate     DateTime?
  status         String?
  tenant         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  qbCustomerId   String?
  qbDocNumber    String?
  qbEstimateId   String?   @unique
  qbSyncedAt     DateTime?

  @@index([customerEmail])
  @@index([customerName])
  @@index([qbEstimateId])
  @@index([status])
  @@index([tenant])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Prospect {
  id                  String                   @id
  whitepagesId        String?
  projectId           String?
  name                String
  aliases             Json?
  isDead              Boolean                  @default(false)
  dateOfBirth         String?
  phones              Json?
  emails              Json?
  currentAddresses    Json?
  historicAddresses   Json?
  ownedProperties     Json?
  linkedinUrl         String?
  companyName         String?
  jobTitle            String?
  relatives           Json?
  isHomeowner         Boolean                  @default(false)
  isCurrentResident   Boolean                  @default(false)
  lookupAddress       String?
  tenant              String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  status              String?
  campaign            String?
  notes               String?
  search_vector       Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((COALESCE(name, ''::text) || ' '::text) || COALESCE(\"companyName\", ''::text)) || ' '::text) || COALESCE(\"jobTitle\", ''::text)))"))
  enrichedAt          DateTime?
  OrganizationContact OrganizationContact[]
  Project             Project?                 @relation(fields: [projectId], references: [id])
  User                User[]

  @@index([isCurrentResident])
  @@index([isHomeowner])
  @@index([name])
  @@index([projectId])
  @@index([tenant])
  @@index([search_vector], map: "prospect_search_idx", type: Gin)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tenant {
  id         String       @id
  slug       String       @unique
  name       String
  domain     String?
  logoUrl    String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  UserTenant UserTenant[]

  @@index([slug])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id            String                   @id
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  projectId     String?
  tenant        String
  createdAt     DateTime                 @default(now())
  callDate      DateTime?
  campaign      String?
  notes         String?
  status        String?
  flowData      Json?
  flowSlug      String?
  flowType      String?
  qualifyScore  String?
  source        String?
  urgencyLevel  String?
  utmCampaign   String?
  utmMedium     String?
  utmSource     String?
  search_vector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((((((COALESCE(\"firstName\", ''::text) || ' '::text) || COALESCE(\"lastName\", ''::text)) || ' '::text) || COALESCE(email, ''::text)) || ' '::text) || COALESCE(phone, ''::text)) || ' '::text) || COALESCE(address, ''::text)))"))
  coordinates   Json?
  prospectId    String?
  leadSource    String?
  ownerName     String?
  city          String?
  postalCode    String?
  state         String?
  Prospect      Prospect?                @relation(fields: [prospectId], references: [id])

  @@index([campaign])
  @@index([createdAt])
  @@index([flowType])
  @@index([leadSource])
  @@index([prospectId])
  @@index([source])
  @@index([tenant])
  @@index([search_vector], map: "lead_search_idx", type: Gin)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model UserTenant {
  id           String       @id
  userId       String
  tenantId     String
  role         String       @default("member")
  createdAt    DateTime     @default(now())
  Tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  BusinessUser BusinessUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}
