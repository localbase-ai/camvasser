generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id            String                   @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  projectId     String?
  prospectId    String?
  tenant        String
  createdAt     DateTime                 @default(now())
  callDate      DateTime?
  campaign      String?
  notes         String?
  status        String?
  flowData      Json?
  flowSlug      String?
  flowType      String?
  qualifyScore  String?
  dataSource    String?   @map("source")
  leadSource    String?
  urgencyLevel  String?
  utmCampaign   String?
  utmMedium     String?
  utmSource     String?
  ownerName     String?
  search_vector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((((((COALESCE(\"firstName\", ''::text) || ' '::text) || COALESCE(\"lastName\", ''::text)) || ' '::text) || COALESCE(email, ''::text)) || ' '::text) || COALESCE(phone, ''::text)) || ' '::text) || COALESCE(address, ''::text)))"))
  coordinates   Json?
  prospect      Prospect?                @relation(fields: [prospectId], references: [id])

  @@index([tenant])
  @@index([createdAt])
  @@index([campaign])
  @@index([dataSource])
  @@index([leadSource])
  @@index([flowType])
  @@index([prospectId])
  @@index([search_vector], map: "lead_search_idx", type: Gin)
  @@map("User")
}

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  domain    String?
  logoUrl   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users     UserTenant[]

  @@index([slug])
}

model UserTenant {
  id        String       @id @default(cuid())
  userId    String
  tenantId  String
  role      String       @default("member")
  createdAt DateTime     @default(now())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      BusinessUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model BusinessUser {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?
  companyName  String?
  domain       String?
  slug         String?      @unique
  createdAt    DateTime     @default(now())
  approvedAt   DateTime?
  status       String       @default("pending")
  passwordHash String?
  isAdmin      Boolean      @default(false)
  tenants      UserTenant[]

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

model Project {
  id                   String                   @id
  tenant               String?
  companyId            String?
  creatorId            String?
  creatorType          String?
  creatorName          String?
  status               String?
  archived             Boolean                  @default(false)
  public               Boolean                  @default(true)
  name                 String?
  address              String?
  streetAddress2       String?
  city                 String?
  state                String?
  postalCode           String?
  country              String?
  slug                 String?
  projectUrl           String?
  publicUrl            String?
  embeddedProjectUrl   String?
  coordinates          Json?
  geofence             Json?
  featureImage         Json?
  photoCount           Int                      @default(0)
  photos               Json?
  videos               Json?
  documents            Json?
  integrations         Json?
  primaryContact       Json?
  notepad              String?
  lastSyncedAt         DateTime                 @default(now())
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  tags                 Json?
  ccCreatedAt          DateTime?
  ccUpdatedAt          DateTime?
  whitepagesEnrichedAt DateTime?
  search_vector        Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((((((((COALESCE(address, ''::text) || ' '::text) || COALESCE(city, ''::text)) || ' '::text) || COALESCE(state, ''::text)) || ' '::text) || COALESCE(\"postalCode\", ''::text)) || ' '::text) || COALESCE(name, ''::text)) || ' '::text) || COALESCE(notepad, ''::text)))"))
  labels               ProjectLabel[]
  prospects            Prospect[]
  organizations        OrganizationProperty[]

  @@index([tenant])
  @@index([address])
  @@index([city, state])
  @@index([status])
  @@index([ccUpdatedAt])
  @@index([lastSyncedAt])
  @@index([search_vector], map: "project_search_idx", type: Gin)
}

model Prospect {
  id                   String                   @id @default(cuid())
  whitepagesId         String                   @unique
  projectId            String?
  name                 String
  aliases              Json?
  isDead               Boolean                  @default(false)
  dateOfBirth          String?
  phones               Json?
  emails               Json?
  currentAddresses     Json?
  historicAddresses    Json?
  ownedProperties      Json?
  linkedinUrl          String?
  companyName          String?
  jobTitle             String?
  relatives            Json?
  isHomeowner          Boolean                  @default(false)
  isCurrentResident    Boolean                  @default(false)
  lookupAddress        String?
  tenant               String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  status               String?
  campaign             String?
  notes                String?
  search_vector        Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((COALESCE(name, ''::text) || ' '::text) || COALESCE(\"companyName\", ''::text)) || ' '::text) || COALESCE(\"jobTitle\", ''::text)))"))
  project              Project?                 @relation(fields: [projectId], references: [id])
  leads                Lead[]
  organizationContacts OrganizationContact[]

  @@index([projectId])
  @@index([tenant])
  @@index([isHomeowner])
  @@index([isCurrentResident])
  @@index([name])
  @@index([search_vector], map: "prospect_search_idx", type: Gin)
}

model ProjectLabel {
  id           String   @id @default(cuid())
  projectId    String
  labelId      String
  displayValue String
  value        String
  tagType      String
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([value])
}

model Note {
  id         String   @id @default(cuid())
  content    String
  entityType String
  entityId   String
  tenant     String
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([entityType, entityId])
  @@index([tenant])
  @@index([createdAt])
}

model Appointment {
  id              String   @id @default(cuid())
  leadId          String?
  tenant          String
  googleEventId   String?
  summary         String
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int      @default(60)
  location        String?
  notes           String?
  status          String   @default("scheduled")
  eventType       String   @default("sales")
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenant])
  @@index([leadId])
  @@index([startTime])
  @@index([status])
  @@index([eventType])
  @@index([googleEventId])
}

model Proposal {
  id             String    @id @default(cuid())
  proposalId     String    @unique
  customerName   String?
  customerEmail  String?
  proposalAmount Float?
  sentDate       DateTime?
  signedDate     DateTime?
  status         String?
  tenant         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenant])
  @@index([customerEmail])
  @@index([customerName])
  @@index([status])
}

model BackgroundJob {
  id        String   @id @default(cuid())
  type      String
  status    String   @default("pending")
  input     Json?
  result    Json?
  error     String?
  progress  Int      @default(0)
  total     Int      @default(0)
  tenant    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([tenant])
  @@index([createdAt])
}

model Organization {
  id         String   @id @default(cuid())
  name       String
  type       String   // hoa, property_management, real_estate, church, apartment_complex, other
  address    String?
  city       String?
  state      String?
  postalCode String?
  phone      String?
  email      String?
  website    String?
  notes      String?
  tenant     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contacts   OrganizationContact[]
  properties OrganizationProperty[]

  @@index([tenant])
  @@index([type])
  @@index([name])
}

model OrganizationContact {
  id             String       @id @default(cuid())
  organizationId String
  prospectId     String?
  name           String
  title          String?      // "Property Manager", "HOA President", etc.
  phone          String?
  email          String?
  isPrimary      Boolean      @default(false)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  prospect       Prospect?    @relation(fields: [prospectId], references: [id])

  @@index([organizationId])
  @@index([prospectId])
}

model OrganizationProperty {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  relationship   String       @default("manages") // manages, owns, association
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId])
  @@index([organizationId])
  @@index([projectId])
}
