#!/bin/sh

echo "🔒 Running security checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "No files staged for commit."
  exit 0
fi

# Belt-and-suspenders: block .env files by filename (gitleaks catches secrets,
# but this catches the case where someone stages an .env with only non-secret content)
ENV_FILES=$(echo "$STAGED_FILES" | grep -E '\.env$|\.env\.local$|\.env\.production$|\.env\.development$' || true)
if [ -n "$ENV_FILES" ]; then
  echo ""
  echo "❌ SECURITY: Attempting to commit .env files:"
  echo "$ENV_FILES"
  echo ""
  echo "These files contain secrets and should not be committed."
  echo "Add them to .gitignore instead."
  exit 1
fi

# Run gitleaks on staged changes
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --verbose --redact
  GITLEAKS_EXIT=$?
  if [ $GITLEAKS_EXIT -ne 0 ]; then
    echo ""
    echo "🚨 gitleaks detected secrets in staged changes!"
    echo "Remove secrets from the files above before committing."
    echo ""
    echo "If these are false positives, add the fingerprint to .gitleaksignore"
    echo "or bypass with: git commit --no-verify"
    exit 1
  fi
else
  echo "⚠️  gitleaks not installed — skipping secret scan."
  echo "   Install with: brew install gitleaks"
fi

echo "✅ Security checks passed!"
echo ""

echo "🧪 Running tests..."

# Run tests
npm test -- --run

# Capture the exit code
TEST_EXIT_CODE=$?

if [ $TEST_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Commit aborted."
  echo "Fix the failing tests and try again."
  exit 1
fi

echo ""
echo "✅ All checks passed!"
exit 0
