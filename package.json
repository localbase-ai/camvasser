{
  "name": "camvasser",
  "version": "1.0.0",
  "description": "Turn your CompanyCam projects into lead generation machines",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "build": "npx prisma generate && npm run build:css",
    "build:css": "npx @tailwindcss/cli -i public/styles/input.css -o public/styles/output.css --minify",
    "watch:css": "npx @tailwindcss/cli -i public/styles/input.css -o public/styles/output.css --watch",
    "postinstall": "npx prisma generate",
    "prepare": "git config core.hooksPath .githooks",
    "deploy": "netlify deploy --prod",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "keywords": [
    "companycam",
    "photos",
    "construction"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.2",
    "google-auth-library": "^10.5.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "prisma": "^6.18.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@vitest/ui": "^4.0.1",
    "better-sqlite3": "^12.5.0",
    "daisyui": "^5.5.14",
    "netlify-cli": "^17.0.0",
    "tailwindcss": "^4.1.18",
    "vitest": "^4.0.1"
  }
}
